{
  "name": "module-federation-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --force && (cd packages/shell && npm install --force) && (cd packages/products && npm install --force) && (cd packages/cart && npm install --force) && (cd packages/dashboard && npm install --force)",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:shell": "cd packages/shell && npm run dev",
    "dev:products": "cd packages/products && npm run dev",
    "dev:cart": "cd packages/cart && npm run dev",
    "dev:dashboard": "cd packages/dashboard && npm run dev",
    "build": "concurrently \"npm:build:*\"",
    "build:shell": "cd packages/shell && npm run build",
    "build:products": "cd packages/products && npm run build",
    "build:cart": "cd packages/cart && npm run build",
    "build:dashboard": "cd packages/dashboard && npm run build",
    "lint": "concurrently \"npm:lint:*\"",
    "lint:shell": "cd packages/shell && npm run lint",
    "lint:products": "cd packages/products && npm run lint",
    "lint:cart": "cd packages/cart && npm run lint",
    "lint:dashboard": "cd packages/dashboard && npm run lint",
    "typecheck": "concurrently \"npm:typecheck:*\"",
    "typecheck:shell": "cd packages/shell && npm run typecheck",
    "typecheck:products": "cd packages/products && npm run typecheck",
    "typecheck:cart": "cd packages/cart && npm run typecheck",
    "typecheck:dashboard": "cd packages/dashboard && npm run typecheck",
    "test": "vitest run",
    "test:shell": "vitest run packages/shell/src",
    "test:products": "vitest run packages/products/src",
    "test:cart": "vitest run packages/cart/src",
    "test:dashboard": "vitest run packages/dashboard/src",
    "test:watch": "vitest",
    "test:watch:shell": "vitest packages/shell/src",
    "test:watch:products": "vitest packages/products/src",
    "test:watch:cart": "vitest packages/cart/src",
    "test:watch:dashboard": "vitest packages/dashboard/src",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npm run install:packages",
    "install:packages": "cd packages/shell && npm install --force && cd ../products && npm install --force && cd ../cart && npm install --force && cd ../dashboard && npm install --force"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "sonner": "^2.0.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.30.1",
    "vitest": "^4.1.4"
  }
}
