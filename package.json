{
  "name": "module-federation-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --force && (cd packages/shell && npm install --force) && (cd packages/records && npm install --force) && (cd packages/prescriptions && npm install --force) && (cd packages/analytics && npm install --force) && (cd packages/home && npm install --force)",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:shell": "cd packages/shell && npm run dev",
    "dev:records": "cd packages/records && npm run dev",
    "dev:prescriptions": "cd packages/prescriptions && npm run dev",
    "dev:analytics": "cd packages/analytics && npm run dev",
    "dev:home": "cd packages/home && npm run dev",
    "build": "concurrently \"npm:build:*\"",
    "build:shell": "cd packages/shell && npm run build",
    "build:records": "cd packages/records && npm run build",
    "build:prescriptions": "cd packages/prescriptions && npm run build",
    "build:analytics": "cd packages/analytics && npm run build",
    "build:home": "cd packages/home && npm run build",
    "lint": "eslint .",
    "typecheck": "concurrently \"npm:typecheck:*\"",
    "typecheck:shell": "cd packages/shell && npm run typecheck",
    "typecheck:records": "cd packages/records && npm run typecheck",
    "typecheck:prescriptions": "cd packages/prescriptions && npm run typecheck",
    "typecheck:analytics": "cd packages/analytics && npm run typecheck",
    "typecheck:home": "cd packages/home && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npm run install:packages",
    "install:packages": "cd packages/shell && npm install --force && cd ../records && npm install --force && cd ../prescriptions && npm install --force && cd ../analytics && npm install --force && cd ../home && npm install --force",
    "kill:ports": "npx kill-port 3000 3001 3002 3003 3004",
    "kill:records": "npx kill-port 3001",
    "kill:prescriptions": "npx kill-port 3002",
    "kill:analytics": "npx kill-port 3003",
    "kill:home": "npx kill-port 3004"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "sonner": "^2.0.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.30.1",
    "vitest": "^4.1.4"
  }
}
