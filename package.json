{
  "name": "module-federation-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install --force && (cd packages/shell && pnpm install --force) && (cd packages/records && pnpm install --force) && (cd packages/prescriptions && pnpm install --force) && (cd packages/analytics && pnpm install --force) && (cd packages/home && pnpm install --force)",
    "dev": "concurrently \"pnpm:dev:*\"",
    "dev:shell": "cd packages/shell && pnpm run dev",
    "dev:records": "cd packages/records && pnpm run dev",
    "dev:prescriptions": "cd packages/prescriptions && pnpm run dev",
    "dev:analytics": "cd packages/analytics && pnpm run dev",
    "dev:home": "cd packages/home && pnpm run dev",
    "build": "concurrently \"pnpm:build:*\"",
    "build:shell": "cd packages/shell && pnpm run build",
    "build:records": "cd packages/records && pnpm run build",
    "build:prescriptions": "cd packages/prescriptions && pnpm run build",
    "build:analytics": "cd packages/analytics && pnpm run build",
    "build:home": "cd packages/home && pnpm run build",
    "lint": "eslint .",
    "typecheck": "concurrently \"pnpm:typecheck:*\"",
    "typecheck:shell": "cd packages/shell && pnpm run typecheck",
    "typecheck:records": "cd packages/records && pnpm run typecheck",
    "typecheck:prescriptions": "cd packages/prescriptions && pnpm run typecheck",
    "typecheck:analytics": "cd packages/analytics && pnpm run typecheck",
    "typecheck:home": "cd packages/home && pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "pnpm run install:packages",
    "install:packages": "cd packages/shell && pnpm install --force && cd ../records && pnpm install --force && cd ../prescriptions && pnpm install --force && cd ../analytics && pnpm install --force && cd ../home && pnpm install --force",
    "kill:ports": "pnpm exec kill-port 3000 3001 3002 3003 3004",
    "kill:records": "pnpm exec kill-port 3001",
    "kill:prescriptions": "pnpm exec kill-port 3002",
    "kill:analytics": "pnpm exec kill-port 3003",
    "kill:home": "pnpm exec kill-port 3004"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
