{
  "name": "module-federation-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install",
    "dev": "node ./scripts/ensure-demo-ports.mjs && concurrently --kill-others-on-fail --names shell,products,cart,dashboard \"npm:dev:shell\" \"npm:dev:products\" \"npm:dev:cart\" \"npm:dev:dashboard\"",
    "dev:shell": "npm --prefix packages/shell run dev",
    "dev:products": "npm --prefix packages/products run dev",
    "dev:cart": "npm --prefix packages/cart run dev",
    "dev:dashboard": "npm --prefix packages/dashboard run dev",
    "ports:check": "node ./scripts/ensure-demo-ports.mjs --check",
    "build": "concurrently --names shell,products,cart,dashboard \"npm:build:shell\" \"npm:build:products\" \"npm:build:cart\" \"npm:build:dashboard\"",
    "build:shell": "npm --prefix packages/shell run build",
    "build:products": "npm --prefix packages/products run build",
    "build:cart": "npm --prefix packages/cart run build",
    "build:dashboard": "npm --prefix packages/dashboard run build",
    "lint": "concurrently --names shell,products,cart,dashboard \"npm:lint:shell\" \"npm:lint:products\" \"npm:lint:cart\" \"npm:lint:dashboard\"",
    "lint:shell": "npm --prefix packages/shell run lint",
    "lint:products": "npm --prefix packages/products run lint",
    "lint:cart": "npm --prefix packages/cart run lint",
    "lint:dashboard": "npm --prefix packages/dashboard run lint",
    "typecheck": "concurrently --names shell,products,cart,dashboard \"npm:typecheck:shell\" \"npm:typecheck:products\" \"npm:typecheck:cart\" \"npm:typecheck:dashboard\"",
    "typecheck:shell": "npm --prefix packages/shell run typecheck",
    "typecheck:products": "npm --prefix packages/products run typecheck",
    "typecheck:cart": "npm --prefix packages/cart run typecheck",
    "typecheck:dashboard": "npm --prefix packages/dashboard run typecheck",
    "test": "vitest run",
    "test:shell": "vitest run packages/shell/src",
    "test:products": "vitest run packages/products/src",
    "test:cart": "vitest run packages/cart/src",
    "test:dashboard": "vitest run packages/dashboard/src",
    "test:watch": "vitest",
    "test:watch:shell": "vitest packages/shell/src",
    "test:watch:products": "vitest packages/products/src",
    "test:watch:cart": "vitest packages/cart/src",
    "test:watch:dashboard": "vitest packages/dashboard/src",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npm run install:packages",
    "install:packages": "npm --prefix packages/shell install && npm --prefix packages/products install && npm --prefix packages/cart install && npm --prefix packages/dashboard install"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "sonner": "^2.0.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.30.1",
    "vitest": "^4.1.4"
  }
}
