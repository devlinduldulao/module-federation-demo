{
  "name": "products",
  "version": "1.0.0",
  "scripts": {
    "dev": "rspack serve",
    "build": "rspack build",
    "lint": "npm --prefix ../.. exec eslint -- src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm --prefix ../.. run test -- packages/products/src",
    "test:watch": "npm --prefix ../.. run test:watch -- packages/products/src"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@rspack/plugin-react-refresh": "^1.6.1",
    "react-refresh": "^0.18.0",
    "style-loader": "^4.0.0",
    "css-loader": "^7.1.4",
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "typescript": "^6.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.6.0",
    "webpack-sources": "^3.3.4"
  }
}