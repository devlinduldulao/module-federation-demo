{
  "name": "home",
  "version": "1.0.0",
  "scripts": {
    "dev": "rspack dev --mode development",
    "start": "rspack dev --mode development",
    "build": "rspack build --mode production",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && pnpm exec eslint packages/home/src",
    "test": "pnpm --dir ../.. run test -- packages/home/src",
    "test:watch": "pnpm --dir ../.. run test:watch -- packages/home/src"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@module-federation/runtime-tools": "^2.0.0",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@rspack/dev-server": "^2.0.0",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "react-refresh": "^0.18.0",
    "@tailwindcss/postcss": "^4.2.4",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "typescript": "^6.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.6.0",
    "webpack-sources": "^3.3.4"
  }
}
